{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "env": {
    "BUILD_CONTEXT": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://red-registro-escolar.onrender.com/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}

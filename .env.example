# App
PORT=3000
VITE_APP_ID=red-registro-escolar

# Auth / session
JWT_SECRET=change-me
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Database (MySQL)
# Example: mysql://user:password@localhost:3306/red_registro_escolar
DATABASE_URL=

# Supabase/PostgreSQL (for migration branch)
# Example pooled URL: postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
# Example direct URL: postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL_DIRECT=

# Optional internal service keys
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional analytics
# Use absolute URL (https://analytics.example.com) or root path (/analytics)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

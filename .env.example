# App
PORT=3000
VITE_APP_ID=red-registro-escolar

# Auth / session
JWT_SECRET=change-me
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Database (Supabase/PostgreSQL)
# Prefer direct URL for persistent backend (Render):
# postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
# If needed, add sslmode=require in the URL.
DATABASE_URL=

# Optional internal service keys
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional analytics
# Use absolute URL (https://analytics.example.com) or root path (/analytics)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
